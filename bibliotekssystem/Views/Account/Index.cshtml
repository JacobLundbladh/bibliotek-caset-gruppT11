@model Account

<h1>Login</h1>

@if (ViewBag.ErrorMessage != null)
{
    <p style="color:red">@ViewBag.ErrorMessage</p>
}


<form asp-action="Index" method="post" asp-route-returnurl="@ViewBag.ReturnUrl">
    <table>
        <tr>
            <td>Username</td>
            <td><input asp-for="Username"/></td>
        </tr>
        <tr>
            <td>Password</td>
            <td><input type="password" asp-for="Password"></td>
        </tr>
        <tr>
            <td><input type="submit" value="Login"/></td>
        </tr>
    </table>
</form>
<a class="nav-link text-dark" asp-area="" asp-controller="Account" asp-action="Create">Skapa konto</a>
